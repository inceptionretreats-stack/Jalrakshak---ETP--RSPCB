rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — each signed-in user can read/write only their own doc.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Shared application dataset (industries, ETP entries, readings, alerts,
    // approvals, compliance) stored as a single document. Any signed-in user
    // — the Monitoring Body or an ETP operator — may read and write it.
    match /state/{docId} {
      allow read, write: if request.auth != null;
    }

    // Everything else is denied by default.
  }
}
